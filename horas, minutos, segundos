#include <stdio.h>
#include <stdlib.h>

int main(void) {
     int h,m,s;
    printf("digite o tempo em segundos: ");
    scanf("%d", &s);
    printf("o tempo em horas, minutos e segundos é: ");
    h = s/3600;
    m = (s%3600)/60;
    s = (s%3600)%60;
    printf("%d:%d:%d", h,m,s);
 
     system("pause");
    return 0;
}
